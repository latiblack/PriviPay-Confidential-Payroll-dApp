# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID="your_project_id"

# Sepolia RPC URL (get one at https://infura.io or https://alchemy.com)
VITE_SEPOLIA_RPC="https://sepolia.infura.io/v3/YOUR_KEY"

# Deployed ConfidentialPayroll contract address
VITE_CONTRACT_ADDRESS="0x_your_contract_address"

# Zama FHE Relayer
VITE_RELAYER_URL="https://relayer.testnet.zama.org"
